# Descale Agency — environment variables template
# Copy this file to `.env.local` and fill in real values.
# All Vite-exposed variables MUST be prefixed with VITE_.

# --- Public site ---
VITE_SITE_URL=http://localhost:4028

# --- Contact form email delivery ---
# Inquiries from every form on the site are delivered to info@travomate.com.pl.
# Pick ONE of the options below; if neither is set, the site falls back to
# opening the visitor's mail client with the inquiry pre-filled.
#
# Option A — Web3Forms (recommended, free):
#   1. Register info@travomate.com.pl at https://web3forms.com
#   2. Paste the access key here
# VITE_WEB3FORMS_KEY=your-web3forms-access-key
#
# Option B — Custom backend that accepts JSON
#   `{ subject, formType, summary, data, to }` and forwards to email.
# VITE_CONTACT_FORM_ENDPOINT=https://your-api.example.com/contact

# --- Optional: analytics (self-host or open-source recommended) ---
# VITE_PLAUSIBLE_DOMAIN=
# VITE_UMAMI_WEBSITE_ID=
